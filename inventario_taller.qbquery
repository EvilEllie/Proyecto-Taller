# CONSULTAS


#Consulta inventario con estado de stock
SELECT nombre_pieza,
año,
cantidad,
stock_bajo(cantidad) AS estado_stock
FROM piezas;

#Piezas con stock bajo
SELECT nombre_pieza, cantidad
FROM piezas
WHERE cantidad <= 5;


